generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String?
  username String  @unique
  password String
  avatar   String?
  bio      String?
  posts    Post[]
  token    String  @unique
}

model Post {
  id       Int    @id @default(autoincrement())
  content  String
  author   User   @relation(fields: [authorID], references: [id])
  authorID Int
}
